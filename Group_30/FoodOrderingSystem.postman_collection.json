          "name": "Add Restaurant (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Pizza Place", "type": "text" },
                { "key": "description", "value": "Best pizza in town", "type": "text" },
                { "key": "image", "type": "file" }
