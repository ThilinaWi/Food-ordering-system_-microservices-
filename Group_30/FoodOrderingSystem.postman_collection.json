            "url": { "raw": "http://localhost:3000/api/restaurants", "host": ["http://localhost:3000"], "path": ["api", "restaurants"] }
          }
        },
        {
          "name": "Update Restaurant (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Pizza Place", "type": "text" },
                { "key": "description", "value": "Updated description", "type": "text" },
                { "key": "image", "type": "file" }
              ]
            },
            "url": { "raw": "http://localhost:3000/api/restaurants/:id", "host": ["http://localhost:3000"], "path": ["api", "restaurants", ":id"] }
