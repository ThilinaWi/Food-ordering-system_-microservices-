{
  "info": {
    "_postman_id": "food-ordering-system-microservices",
    "name": "Food Ordering System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Food Ordering System (Microservices) via API Gateway."
  },
  "item": [
    {
      "name": "User Auth & Profile",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/users/register", "host": ["http://localhost:3000"], "path": ["api", "users", "register"] }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/users/login", "host": ["http://localhost:3000"], "path": ["api", "users", "login"] }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/users/:id", "host": ["http://localhost:3000"], "path": ["api", "users", ":id"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3000/api/categories", "host": ["http://localhost:3000"], "path": ["api", "categories"] }
          }
        },
        {
          "name": "Add Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza\",\n  \"description\": \"Italian pizzas\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/categories", "host": ["http://localhost:3000"], "path": ["api", "categories"] }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Pizza\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/categories/:id", "host": ["http://localhost:3000"], "path": ["api", "categories", ":id"] }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/categories/:id", "host": ["http://localhost:3000"], "path": ["api", "categories", ":id"] }
          }
        }
      ]
    },
    {
      "name": "Restaurants",
